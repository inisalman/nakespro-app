// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  reports       Report[]
  invoices      Invoice[]
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Order {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  packageType     String    @default("hemat")
  templateId      String
  palette         String?

  billingCycle    String
  baseAmount      Int
  uniqueCode      Int
  totalAmount     Int
  paymentStatus   String    @default("pending")
  paymentProofUrl String?
  nextBillingDate DateTime?
  lastPaidAt      DateTime?

  isActive        Boolean   @default(false)
  suspendedAt     DateTime?

  fullName        String?
  websiteName     String?
  description     String?
  serviceType     String?
  waNumber        String?
  practiceHours   String?
  location        String?
  googleMaps      String?

  photos          OrderPhoto[]
  pageviews       PageView[]
  invoices        Invoice[]

  buildStatus     String    @default("awaiting_payment")
  subdomain       String?   @unique
  websiteUrl      String?
  adminNotes      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([nextBillingDate, paymentStatus])
}

model OrderPhoto {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  url       String
  caption   String?

  createdAt DateTime @default(now())
}

/// Kunjungan ke website client ({nama}.nakespro.id) yang dicatat via beacon.
model PageView {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  /// SHA-256 hash dari IP + User-Agent. Tidak menyimpan IP asli.
  visitorHash String

  /// Path yang dikunjungi (mis. "/", "/layanan").
  path        String
  /// Referrer URL atau null untuk direct visit.
  referrer    String?
  /// User-Agent mentah, di-truncate 200 char. Untuk breakdown device nanti.
  userAgent   String

  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([orderId, visitorHash, createdAt])
}

/// Laporan tindakan + invoice yang dibuat nakes untuk pasien.
model Report {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identitas invoice
  invoiceNumber String  @unique
  status        String  @default("draft") // draft | sent | paid

  // Data pasien
  patientName     String
  patientWaNumber String

  // Detail tindakan
  actionDate        DateTime
  actionType        String
  actionDescription String?

  // Line items biaya: [{ name: string, qty: number, price: number }]
  items      Json

  // Rincian tambahan
  notes       String?
  totalAmount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Riwayat tagihan langganan nakes (per siklus pembayaran).
/// Berbeda dari Report (invoice pasien), ini untuk langganan website NakesPro itu sendiri.
model Invoice {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])

  // Identitas tagihan
  invoiceNumber String   @unique // TAG-2026-0001
  billingCycle  String // monthly | yearly

  // Periode langganan yang ditagih
  periodStart   DateTime
  periodEnd     DateTime

  // Nominal (IDR)
  baseAmount    Int
  uniqueCode    Int
  totalAmount   Int

  // Status pembayaran: pending | claimed | paid | overdue
  status        String   @default("pending")
  paymentProofUrl String?

  issuedAt      DateTime @default(now())
  paidAt        DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([orderId])
  @@index([status])
}
